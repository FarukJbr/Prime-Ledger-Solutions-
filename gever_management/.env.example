# ============================================
# GEVER MANAGEMENT SYSTEM - Environment Variables
# גבר יזמות ייעוץ עסקי והשקעות
# ============================================
# Copy this file to .env and fill in your values
# אל תשתף קובץ זה עם אף אחד!

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_KEY=eyJhbGci...

# --- Telegram (optional - not required if using web dashboard) ---
TELEGRAM_BOT_TOKEN=optional
TELEGRAM_CHAIRMAN_CHAT_ID=0

# --- Dashboard Login ---
DASHBOARD_USER=chairman
DASHBOARD_PASSWORD=your-secret-password

# --- Meta (Facebook + Instagram) ---
META_ACCESS_TOKEN=
META_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=

# --- TikTok ---
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# --- App Settings ---
COMPANY_NAME=גבר יזמות ייעוץ עסקי והשקעות
COMPANY_NAME_EN=Gever Entrepreneurship Business Consulting and Investments
DEFAULT_LANGUAGE=he
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
